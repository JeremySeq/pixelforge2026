            "height": 357.9999694824219
        }
    },
    "m_Slots": [
        {
            "m_Id": "2c6a783eda5642f0be7812badcf2f39c"
        },
        {
            "m_Id": "ace292b4ce6041c9b6586ab458c18bd6"
        },
        {
            "m_Id": "8da69386780a46f893703925d62ac648"
        },
        {
            "m_Id": "af1000c5caaf41ffbe767b3e17c48027"
        },
        {
            "m_Id": "91982feb91ea4bce9ee6f40ed463e583"
        },
        {
            "m_Id": "8e6b87682e67487aaa53806eb0c374f0"
        },
        {
            "m_Id": "19185c3256204813af52d6ef020b58dd"
        },
        {
            "m_Id": "2de3e6c819b04bdda350fb26cfbd1cbe"
        },
        {
            "m_Id": "3728c7a11f354ecaba04c7871fa24059"
        },
        {
            "m_Id": "0e41d26d526244f38acdab4268312a20"
        },
        {
            "m_Id": "088ab1135abf4e15a4760cbaa0ca1810"
        },
        {
            "m_Id": "04113d4a626b4218b5d74634f1bcabe0"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 0,
    "m_FunctionName": "raymarch",
    "m_FunctionSource": "b8ef7d317c8d506b2bb462b4f2550399",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float depth = SHADERGRAPH_SAMPLE_SCENE_DEPTH(screenUV);\nfloat3 worldPos = ComputeWorldSpacePosition(screenUV, depth, UNITY_MATRIX_I_VP);\n\nfloat3 entryPoint = cameraPos;\nfloat3 viewDir = worldPos - cameraPos;\nfloat viewLength = length(viewDir);\nfloat3 rayDir = normalize(viewDir);\n\nfloat2 pixelCoords = screenUV * _ScreenParams.xy;\nfloat distLimit = min(viewLength, maxDistance);\nfloat distTravelled = InterleavedGradientNoise(pixelCoords, (int)(Time / max(1e-5, deltaTime))) * stepNoise;\nfloat transmittance = 1.0;\n\nwhile (distTravelled < distLimit)\n{\n\tfloat3 rayPos = entryPoint + rayDir * distTravelled;\n\tfloat4 noise = fogNoise.SampleLevel(noiseSampler, rayPos * 0.01 * noiseScale, 0);\n\tfloat density = dot(noise, noise);\n\tdensity = saturate(density - densityThreshold) * densityMultiplier);\n\n\tif (density > 0)\n\t{\n\t\ttransmittance *= exp(-density * stepSize);\n\t}\n\tdistTravelled += stepSize;\n}"
}

